	<declaration>
// ===== Constants -- each traced to one requirement =====
const int MAX_TRUCKS = 4;             // platoon capacity (2 followers instantiated)
const int NOTIFICATION_LATENCY = 100; // ms (REQ-1.5.1)
const int V2X_CYCLE = 20;             // ms = 50 Hz data exchange (REQ-1.2.3)
const int SYNC_TIMEOUT = 3000;        // ms (REQ-1.3.2): speed sync completes within 3 s
const int GAP_CLOSE_TIMEOUT = 5000;   // ms (REQ-1.6.2): gap closed within 5 s

typedef int[0, MAX_TRUCKS-1] truck_id;

// ===== Channels =====
// Truck -&gt; Lead
chan joinRequest[MAX_TRUCKS];
chan leaveRequest[MAX_TRUCKS];
chan exitConfirmed[MAX_TRUCKS];
chan syncFailed[MAX_TRUCKS];      // state machine: syncFailed()/abortJoin()
chan gapClosed;                   // state machine: gapClosed()/confirmFormation()

// Lead -&gt; SafetyOperator
chan requestApproval[MAX_TRUCKS];

// SafetyOperator -&gt; Lead AND Truck (broadcast: both hear one decision)
broadcast chan operatorApproves[MAX_TRUCKS];
broadcast chan operatorRejects[MAX_TRUCKS];

// Lead -&gt; Truck
chan conditionsSafe[MAX_TRUCKS];
chan conditionsUnsafe[MAX_TRUCKS];
chan linkEstablished[MAX_TRUCKS];
chan speedSynced[MAX_TRUCKS];
broadcast chan predecessorLeft;   // state machine: predecessorLeft()/calculateNewGap() -- remaining member closes the gap

// ===== Shared state =====
int[0, MAX_TRUCKS] members = 0;       // platoon member count, maintained by the lead
bool isPlatoonLocked = false;         // == members &gt; 0, maintained by the lead
int[0, 50] current_gap = 50;          // m (REQ-1.1.2)
int[-10, 10] speed_dev[MAX_TRUCKS];   // scaled x10: +/-5 == +/-0.5 m/s (REQ-1.3.1)

// Simplification kept: the lead coordinates one join/leave maneuver at a time,
// but the platoon may now hold multiple members -- so when one member leaves,
// the remaining member closes the gap (ClosingGap inside Active Platooning,
// per the state machine). REQ-1.6.1's separate 500 ms begin-bound is out of scope.

// ===== Communication-loss scenario (merged from truck_platoon_uppaal.xml, generalized to N trucks) =====
// Scope: the watchdog only monitors ACTIVE_PLATOONING_SteadyState -- the ordinary
// cruising state. Comm loss during the short, already-timed ClosingGap maneuver is
// out of scope for this iteration, same trade-off style as REQ-1.6.1 above.
const int COMM_TIMEOUT = 3 * V2X_CYCLE; // ms: 3 missed 50 Hz heartbeats =&gt; link declared lost
const int SAFE_MODE_DELAY = 20;         // ms: must fall back to independent/safe driving within this bound
const int RECONNECT_LIMIT = 100;        // abstract reconnection-window ceiling. Distance/attempt-driven,
                                         // so a small ceiling is exact for the untimed reachability props
                                         // (same trade-off as GAP_CLOSE_TIMEOUT). Kept well above
                                         // SAFE_MODE_DELAY and small enough to keep the zone graph tight.

broadcast chan heartbeat;         // Lead -&gt; all current members: single shared V2X beacon
broadcast chan commWarning[MAX_TRUCKS]; // Follower[id] -&gt; SafetyOperator: loss detected (monitoring only)
broadcast chan commRejoin[MAX_TRUCKS];  // Follower[id] -&gt; SafetyOperator: link recovered (monitoring only)
chan commGiveUp[MAX_TRUCKS];      // Follower[id] -&gt; Lead: reconnection window expired, unilateral exit
                                   // (non-broadcast: reuses the serialized handshake pattern, so it
                                   // blocks until the lead is back in PlatoonSteadyState)

bool isMember[MAX_TRUCKS];        // true once truck id has completed JOINING, false once it has exited

// ===== Maneuver serialization (prevents the comm-loss / voluntary-leave interleaving deadlock) =====
// A comm-lost member is still counted in the platoon, but it is NOT in SteadyState, so it cannot
// perform the gap-closing handshake the lead expects after a voluntary leave. We therefore make the
// two maneuvers mutually exclusive: a coordinated decouple never starts while any member is handling
// comm loss, and comm-loss handling never starts mid-decouple. This is also realistic -- you stabilize
// a comms fault before running a coordinated leave. A truck giving up on reconnection exits WITHOUT
// gap closing (there is, by definition, no link to coordinate that maneuver over).
int[0, MAX_TRUCKS] commActive = 0;  // number of members currently handling comm loss
bool leaveInProgress = false;       // a coordinated voluntary-leave maneuver is underway
	</declaration>
