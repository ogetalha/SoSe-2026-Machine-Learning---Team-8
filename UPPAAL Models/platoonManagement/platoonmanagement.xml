	<system>
truck0 = FollowerTruck(0);
truck1 = FollowerTruck(1);
lead = LeadTruck();
op = SafetyOperator();

system truck0, truck1, lead, op;
	</system>
	<queries>
		<query>
			<formula>A[] not deadlock</formula>
			<comment>The system can never freeze. The remaining member is always in SteadyState when predecessorLeft is broadcast (the lead serializes maneuvers), so the gap-closing handshake is always available.</comment>
			<result outcome="success" type="quality" timestamp="2026-07-09 02:45:41 +0200">
			</result>
		</query>
		<query>
			<formula>A[] (truck0.JOINING_SynchronizingSpeed imply (speed_dev[0] &lt;= 5 and speed_dev[0] &gt;= -5))</formula>
			<comment>REQ-1.3.1: speed deviation never exceeds +/-0.5 m/s (scaled +/-5) during synchronization.</comment>
			<result outcome="success" type="quality" timestamp="2026-07-09 02:45:42 +0200">
			</result>
		</query>
		<query>
			<formula>A[] (truck0.JOINING_SynchronizingSpeed imply truck0.t &lt;= SYNC_TIMEOUT)</formula>
			<comment>REQ-1.3.2: synchronization never runs longer than 3 s -- success (speedSynced) or abort (syncFailed) at the deadline.</comment>
			<result outcome="success" type="quality" timestamp="2026-07-09 02:45:44 +0200">
			</result>
		</query>
		<query>
			<formula>A[] (truck0.ACTIVE_PLATOONING_SteadyState imply truck0.v2x_clk &lt;= V2X_CYCLE)</formula>
			<comment>REQ-1.2.3: never more than 20 ms (50 Hz) between V2X refreshes in steady state.</comment>
			<result outcome="success" type="quality" timestamp="2026-07-09 02:45:45 +0200">
			</result>
		</query>
		<query>
			<formula>A[] (truck0.ACTIVE_PLATOONING_ClosingGap imply truck0.v2x_clk &lt;= V2X_CYCLE)</formula>
			<comment>REQ-1.2.3 during the gap maneuver: the closing truck is still a platoon member and keeps the 50 Hz exchange.</comment>
			<result outcome="success" type="quality" timestamp="2026-07-09 02:45:46 +0200">
			</result>
		</query>
		<query>
			<formula>A[] (truck0.ACTIVE_PLATOONING_SteadyState imply speed_dev[0] == 0)</formula>
			<comment>Safety: a truck is only ever in steady-state platooning with zero speed deviation.</comment>
			<result outcome="success" type="quality" timestamp="2026-07-09 02:45:47 +0200">
			</result>
		</query>
		<query>
			<formula>A[] (truck0.JOINING_ValidatingConditions imply truck0.t &lt;= NOTIFICATION_LATENCY)</formula>
