<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC '-//Uppaal Team//DTD Flat System 1.6//EN' 'http://www.it.uu.se/research/group/darts/uppaal/flat-1_6.dtd'>
<nta>
	<declaration>
// Global Constants from Requirements
const int MAX_TRUCKS = 4;
const int NOTIFICATION_LATENCY = 100; // ms (REQ-1.5.1)
const int V2X_CYCLE = 20;             // ms (50 Hz data exchange from REQ-1.2.3)
const int GAP_CLOSE_TIMEOUT = 5000;   // ms (5 seconds from REQ-1.6.2)

typedef int[0, MAX_TRUCKS-1] truck_id;

// Channels for Synchronization
chan joinRequest[MAX_TRUCKS];
chan operatorApproves[MAX_TRUCKS];
chan operatorRejects[MAX_TRUCKS];
chan conditionsSafe[MAX_TRUCKS];
chan conditionsUnsafe[MAX_TRUCKS];
chan linkEstablished[MAX_TRUCKS];
chan speedSynced[MAX_TRUCKS];

chan leaveRequest[MAX_TRUCKS];
chan ackLeave[MAX_TRUCKS];
chan notifyMembers;
chan exitConfirmed[MAX_TRUCKS];

chan predecessorLeft;
chan gapClosed;
chan linkFailed;

// Shared State Variables
bool isPlatoonLocked = false;
int[0, 50] current_gap = 50; // meters (REQ-1.1.2)

// Quantitative Metrics System (REQ-1.3.1)
// Representing speed deviation scaled by 10 (-5 to +5 maps to -0.5 m/s to +0.5 m/s)
int[-10, 10] speed_dev[MAX_TRUCKS]; 
	</declaration>
	<template>
		<name x="5" y="5">FollowerTruck</name>
		<parameter>const truck_id id</parameter>
		<declaration>
clock t;
clock v2x_clk; // Heartbeat clock for the 50 Hz cycle (REQ-1.2.3)
		</declaration>
		<location id="id0" x="0" y="-300">
			<name x="17" y="-331">Idle</name>
		</location>
		<location id="id1" x="-250" y="-150">
			<name x="-331" y="-187">JOINING_JoinRequested</name>
		</location>
		<location id="id2" x="-250" y="-50">
			<name x="-229" y="-68">JOINING_ValidatingConditions</name>
			<label kind="invariant" x="-221" y="-51">t &lt;= NOTIFICATION_LATENCY</label>
		</location>
		<location id="id3" x="-250" y="50">
			<name x="-229" y="42">JOINING_EstablishingLink</name>
		</location>
		<location id="id4" x="-250" y="150">
			<name x="-493" y="161">JOINING_SynchronizingSpeed</name>
			<label kind="invariant" x="-187" y="161">t &lt;= 3000</label>
		</location>
		<location id="id5" x="-450" y="0">
			<name x="-680" y="-8">JOINING_LinkReconnection</name>
			<label kind="invariant" x="-620" y="17">t &lt;= 3000</label>
		</location>
		<location id="id6" x="0" y="300">
			<name x="25" y="306">ACTIVE_PLATOONING_SteadyState</name>
			<label kind="invariant" x="25" y="323">v2x_clk &lt;= V2X_CYCLE</label>
		</location>
		<location id="id7" x="250" y="150">
			<name x="272" y="144">LEAVING_LeaveRequested</name>
		</location>
		<location id="id8" x="250" y="50">
			<name x="272" y="42">LEAVING_ValidatingExit</name>
		</location>
		<location id="id9" x="246" y="-136">
			<name x="263" y="-144">LEAVING_ExecutingExit</name>
		</location>
		<init ref="id0"/>
		<transition id="id10">
			<source ref="id6"/>
			<target ref="id5"/>
			<label kind="synchronisation" x="-331" y="399">linkFailed?</label>
			<nail x="-144" y="382"/>
			<nail x="-450" y="382"/>
		</transition>
		<transition id="id11">
			<source ref="id0"/>
			<target ref="id1"/>
			<label kind="synchronisation" x="-180" y="-240">joinRequest[id]!</label>
			<label kind="assignment" x="-180" y="-220">t = 0, speed_dev[id] = 0</label>
		</transition>
		<transition id="id12">
			<source ref="id1"/>
			<target ref="id2"/>
			<label kind="synchronisation" x="-238" y="-127">operatorApproves[id]?</label>
			<label kind="assignment" x="-238" y="-102">t = 0</label>
		</transition>
		<transition id="id13">
			<source ref="id1"/>
			<target ref="id0"/>
			<label kind="synchronisation" x="-76" y="-153">operatorRejects[id]?</label>
			<nail x="0" y="-153"/>
		</transition>
		<transition id="id14">
			<source ref="id2"/>
			<target ref="id3"/>
			<label kind="synchronisation" x="-238" y="-17">conditionsSafe[id]?</label>
			<label kind="assignment" x="-238" y="0">t = 0</label>
		</transition>
		<transition id="id15">
			<source ref="id2"/>
			<target ref="id0"/>
			<label kind="synchronisation" x="-365" y="-255">conditionsUnsafe[id]?</label>
			<nail x="-380" y="-50"/>
			<nail x="-380" y="-300"/>
		</transition>
		<transition id="id16">
			<source ref="id3"/>
			<target ref="id4"/>
			<label kind="synchronisation" x="-238" y="76">linkEstablished[id]?</label>
			<label kind="assignment" x="-238" y="93">t = 0</label>
		</transition>
		<transition id="id17">
			<source ref="id4"/>
			<target ref="id4"/>
			<label kind="select" x="-204" y="144">v : int[-5,5]</label>
			<label kind="assignment" x="-212" y="127">speed_dev[id] = v</label>
			<nail x="-210" y="110"/>
			<nail x="-210" y="130"/>
		</transition>
		<transition id="id18">
			<source ref="id3"/>
			<target ref="id5"/>
			<label kind="synchronisation" x="-399" y="42">linkFailed?</label>
		</transition>
		<transition id="id19">
			<source ref="id5"/>
			<target ref="id0"/>
			<label kind="guard" x="-433" y="-337">t &gt;= 3000</label>
			<nail x="-450" y="-365"/>
			<nail x="-374" y="-365"/>
			<nail x="0" y="-365"/>
		</transition>
		<transition id="id20">
			<source ref="id4"/>
			<target ref="id6"/>
			<label kind="guard" x="-238" y="204">speed_dev[id] == 0</label>
			<label kind="synchronisation" x="-238" y="229">speedSynced[id]?</label>
			<label kind="assignment" x="-425" y="306">isPlatoonLocked = true, v2x_clk = 0</label>
			<nail x="-250" y="300"/>
			<nail x="-17" y="297"/>
		</transition>
		<transition id="id21">
			<source ref="id6"/>
			<target ref="id6"/>
			<label kind="guard" x="-59" y="391">v2x_clk == V2X_CYCLE</label>
			<label kind="assignment" x="-60" y="410">v2x_clk = 0</label>
			<nail x="-30" y="380"/>
			<nail x="30" y="380"/>
		</transition>
		<transition id="id22">
			<source ref="id6"/>
			<target ref="id7"/>
			<label kind="synchronisation" x="93" y="195">leaveRequest[id]!</label>
			<label kind="assignment" x="144" y="221">t = 0</label>
			<nail x="250" y="300"/>
		</transition>
		<transition id="id23">
			<source ref="id7"/>
			<target ref="id8"/>
			<label kind="synchronisation" x="263" y="85">operatorApproves[id]?</label>
			<label kind="assignment" x="263" y="102">t = 0</label>
		</transition>
		<transition id="id24">
			<source ref="id8"/>
			<target ref="id9"/>
			<label kind="synchronisation" x="255" y="-68">conditionsSafe[id]?</label>
			<label kind="assignment" x="255" y="-51">t = 0</label>
		</transition>
		<transition id="id25">
			<source ref="id8"/>
			<target ref="id6"/>
			<label kind="synchronisation" x="-8" y="93">conditionsUnsafe[id]?</label>
			<nail x="100" y="50"/>
		</transition>
		<transition id="id26">
			<source ref="id9"/>
			<target ref="id0"/>
			<label kind="synchronisation" x="263" y="-255">exitConfirmed[id]!</label>
			<label kind="assignment" x="255" y="-229">isPlatoonLocked = false</label>
			<nail x="246" y="-297"/>
		</transition>
	</template>
	<template>
		<name>LeadTruck</name>
		<declaration>
clock t;
truck_id active_id;
		</declaration>
		<location id="id27" x="-620" y="-102">
			<name x="-630" y="-132">Idle</name>
		</location>
		<location id="id28" x="-297" y="-102">
			<name x="-360" y="-138">AuthorizingJoin</name>
		</location>
		<location id="id29" x="0" y="-100">
			<name x="-40" y="-130">MonitorValidation</name>
		</location>
		<location id="id30" x="297" y="-102">
			<name x="257" y="-132">ConfirmHandshake</name>
		</location>
		<location id="id31" x="637" y="-102">
			<name x="597" y="-132">TrackSpeedSync</name>
		</location>
		<location id="id32" x="484" y="102">
			<name x="454" y="122">PlatoonSteadyState</name>
		</location>
		<location id="id33" x="195" y="102">
			<name x="155" y="122">AuthorizingLeave</name>
		</location>
		<location id="id34" x="-102" y="102">
			<name x="-142" y="122">ExecutingLeave</name>
		</location>
		<location id="id35" x="-459" y="102">
			<name x="-544" y="136">ClosingGapState</name>
			<label kind="invariant" x="-578" y="161">t &lt;= GAP_CLOSE_TIMEOUT</label>
		</location>
		<init ref="id27"/>
		<transition id="id36">
			<source ref="id27"/>
			<target ref="id28"/>
			<label kind="select" x="-501" y="-127">i : truck_id</label>
			<label kind="synchronisation" x="-510" y="-144">joinRequest[i]?</label>
			<label kind="assignment" x="-501" y="-102">active_id = i</label>
		</transition>
		<transition id="id37">
			<source ref="id28"/>
			<target ref="id29"/>
			<label kind="synchronisation" x="-272" y="-93">operatorApproves[active_id]!</label>
		</transition>
		<transition id="id38">
			<source ref="id29"/>
			<target ref="id30"/>
			<label kind="synchronisation" x="34" y="-93">conditionsSafe[active_id]!</label>
		</transition>
		<transition id="id39">
			<source ref="id29"/>
			<target ref="id27"/>
			<label kind="synchronisation" x="-348" y="-34">conditionsUnsafe[active_id]!</label>
			<nail x="0" y="-40"/>
			<nail x="-400" y="-40"/>
		</transition>
		<transition id="id40">
			<source ref="id30"/>
			<target ref="id31"/>
			<label kind="synchronisation" x="348" y="-93">linkEstablished[active_id]!</label>
		</transition>
		<transition id="id41">
			<source ref="id31"/>
			<target ref="id32"/>
			<label kind="synchronisation" x="340" y="-8">speedSynced[active_id]!</label>
		</transition>
		<transition id="id42">
			<source ref="id32"/>
			<target ref="id33"/>
			<label kind="synchronisation" x="246" y="76">leaveRequest[active_id]?</label>
		</transition>
		<transition id="id43">
			<source ref="id33"/>
			<target ref="id34"/>
			<label kind="synchronisation" x="-68" y="76">operatorApproves[active_id]!</label>
		</transition>
		<transition id="id44">
			<source ref="id34"/>
			<target ref="id35"/>
			<label kind="synchronisation" x="-357" y="76">exitConfirmed[active_id]?</label>
			<label kind="assignment" x="-280" y="110">t = 0</label>
		</transition>
		<transition id="id45">
			<source ref="id35"/>
			<target ref="id32"/>
			<label kind="guard" x="-34" y="212">t &lt;= GAP_CLOSE_TIMEOUT</label>
			<label kind="assignment" x="8" y="238">current_gap = 4</label>
			<nail x="-250" y="200"/>
			<nail x="400" y="200"/>
		</transition>
	</template>
	<template>
		<name>SafetyOperator</name>
		<parameter>const truck_id id</parameter>
		<location id="id46" x="0" y="0">
			<name x="-10" y="-30">Idle</name>
		</location>
		<location id="id47" x="263" y="0">
			<name x="266" y="-34">Evaluating</name>
		</location>
		<init ref="id46"/>
		<transition id="id48">
			<source ref="id46"/>
			<target ref="id47"/>
			<label kind="synchronisation" x="59" y="-25">operatorApproves[id]?</label>
		</transition>
		<transition id="id49">
			<source ref="id47"/>
			<target ref="id46"/>
			<label kind="synchronisation" x="34" y="85">operatorApproves[id]!</label>
			<nail x="136" y="85"/>
			<nail x="86" y="85"/>
		</transition>
	</template>
	<system>
truck0 = FollowerTruck(0);
truck1 = FollowerTruck(1);
op0 = SafetyOperator(0);
op1 = SafetyOperator(1);
lead = LeadTruck();

system truck0, truck1, lead, op0, op1;
	</system>
	<queries>
		<query>
			<formula>A[] not deadlock</formula>
			<comment/>
		</query>
		<query>
			<formula>A[] (FollowerTruck(0).JOINING_SynchronizingSpeed imply (speed_dev[0] &lt;= 5 and speed_dev[0] &gt;= -5))</formula>
			<comment>Verification: Mathematical proof that speed tolerance never exceeds the strict +/- 0.5 m/s requirement during synchronization.</comment>
		</query>
		<query>
			<formula>A[] (FollowerTruck(0).ACTIVE_PLATOONING_SteadyState imply FollowerTruck(0).v2x_clk &lt;= 20)</formula>
			<comment>Verification: Proves that time cannot progress past 20ms without refreshing data, confirming structural compliance with the 50 Hz requirement.</comment>
		</query>
	</queries>
</nta>
